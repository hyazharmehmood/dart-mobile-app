meta {
  name: mark-on-the-way
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/driver/orders/{{orderId}}/status
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{driverAccessToken}}
  Content-Type: application/json
}

body:json {
  {
    "status": "ON_THE_WAY"
  }
}

docs {
  Use after PICKED_UP to start the delivery route.
}
