meta {
  name: update-order-status
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/api/driver/orders/{{orderId}}/status
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{driverAccessToken}}
}

body:json {
  {
    "status": "PICKED_UP"
  }
}

docs {
  Preferred transitions after accept: READY -> PICKED_UP -> ON_THE_WAY -> DELIVERED.
  Temporary legacy support allows READY -> ON_THE_WAY.
  Driver earning is created when status becomes DELIVERED.
}
