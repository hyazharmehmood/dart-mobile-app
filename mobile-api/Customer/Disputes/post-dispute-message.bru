meta {
  name: post-dispute-message
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/customer/disputes/{{disputeId}}/messages
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{customerAccessToken}}
  Content-Type: application/json
}

body:json {
  {
    "body": "I can share more details about the missing item."
  }
}

docs {
  Posts a participant message on an open dispute.

  Messaging is allowed while status is OPEN, IN_REVIEW, or WAITING_FOR_RESPONSE.
}
