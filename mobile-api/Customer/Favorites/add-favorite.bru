meta {
  name: add-favorite
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/customer/favorites
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{customerAccessToken}}
  Content-Type: application/json
}

body:json {
  {
    "restaurantId": "{{restaurantId}}"
  }
}

docs {
  Saves an approved restaurant to the customer's favorites list.

  Idempotent for the same restaurantId.
}
