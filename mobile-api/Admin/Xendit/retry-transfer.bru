meta {
  name: retry-transfer
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/admin/xendit/transfers/{{providerTransferId}}/retry
  body: none
  auth: none
}

headers {
  Cookie: {{adminSessionCookie}}
}

docs {
  Retries a failed or stale pending Xendit transfer with the same deterministic
  transfer reference. Does not create duplicate money movement.
}
