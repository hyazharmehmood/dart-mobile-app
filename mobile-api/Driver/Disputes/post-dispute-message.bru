meta {
  name: post-dispute-message
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/driver/disputes/{{disputeId}}/messages
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{driverAccessToken}}
  Content-Type: application/json
}

body:json {
  {
    "body": "I waited at the gate for 10 minutes and called the customer."
  }
}

docs {
  Posts a participant message on an open dispute.
}
