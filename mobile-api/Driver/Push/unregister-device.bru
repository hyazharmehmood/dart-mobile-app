meta {
  name: unregister-device
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/api/mobile/devices/{{deviceId}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{driverAccessToken}}
}

docs {
  Driver logout: unregister the device returned from register-device. See docs/mobile-push-notifications.md.
}
