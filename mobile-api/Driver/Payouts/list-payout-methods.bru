meta {
  name: list-payout-methods
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/driver/payout-methods
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{driverAccessToken}}
}

docs {
  Returns the driver's bank, e-wallet, and cash-pickup methods with approval status,
  masked account details, and default-method state.
}
