meta {
  name: mark-delivered
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/api/driver/orders/{{orderId}}/status
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{driverAccessToken}}
  Content-Type: application/json
}

body:json {
  {
    "status": "DELIVERED"
  }
}

docs {
  Use after ON_THE_WAY. This creates the driver delivery earning once.
}
